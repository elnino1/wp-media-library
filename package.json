{
  "name": "wp-media-folders",
  "version": "1.0.0",
  "description": "Desktop-class Media Library Folders for WordPress",
  "main": "build/index.js",
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "package": "wp-scripts plugin-zip",
    "test:unit": "wp-scripts test-unit-js",
    "test:php": "wp-env run tests-cli --env-cwd=wp-content/plugins/wp-media-library ./vendor/bin/phpunit",
    "env:start": "wp-env start",
    "env:stop": "wp-env stop",
    "env:destroy": "wp-env destroy"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2"
  },
  "devDependencies": {
    "@testing-library/react": "^14.0.0",
    "@wordpress/env": "^9.0.0",
    "@wordpress/scripts": "^27.0.0"
  }
}